<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.DetailPage"
             xmlns:viewmodel="clr-namespace:MauiApp1.ViewModels"
             x:DataType="viewmodel:DetailViewModel"
             Title="{Binding Goal.Name}">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="{Binding Goal.Name}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />

        <Label Text="{Binding Goal.Category, StringFormat='Category: {0}'}" FontSize="16" TextColor="Gray" HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

        <Label Text="Motivation:" FontAttributes="Bold" FontSize="18" />
        <Label Text="{Binding Goal.Motivation}" FontSize="16" FontAttributes="Italic" />

        <Label Text="Target Date:" FontAttributes="Bold" FontSize="18" Margin="0,10,0,0" />
        <Label Text="{Binding Goal.TargetDate, StringFormat='{0:MMMM dd, yyyy}'}" FontSize="16" />

        <Label Text="Progress:" FontAttributes="Bold" FontSize="18" Margin="0,10,0,0" />
        <ProgressBar Progress="{Binding Goal.Progress}" ProgressColor="Teal" Margin="0,5" />
        <Label Text="{Binding Goal.Progress, StringFormat='{0:P0}'}" HorizontalOptions="End" />
    </VerticalStackLayout>
</ContentPage>